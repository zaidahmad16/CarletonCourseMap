      "concurrent_prerequisites": []
    },
    {
      "code": "CGSC 4900",
      "name": "Special Topics in Cognitive Science",
      "credit": "",
      "description": "The topic of this course will vary from year to year. Students may register in more than one section of  CGSC 4900  but may register in each section only once.",
      "prerequisites": "each section will have its own prerequisites and permission of the department if is required.",
      "offerings": [
        "winter"
      ],
      "year_standing": null,
      "concurrent_prerequisites": []
    },
    {
      "code": "CGSC 4908",
      "name": "Honours Thesis",
      "credit": "",
      "description": "Interdisciplinary thesis.  In developing a thesis, students must consult the Undergraduate Supervisor. Only the Undergraduate Supervisor can assign a supervisor or grant approval to register in this course. Faculty regulations governing Honours Research Essays and Honours Theses apply.",
      "prerequisites": "fourth year standing, CGSC 3908 , and enrolment in B.Cog.Sc. Honours with a major CGPA of 8.0.",
      "offerings": [
        "fall",
        "winter"
      ],
      "year_standing": 4,
      "concurrent_prerequisites": []
    },
    {
      "code": "CGSC 4909",
      "name": "Honours Project",
      "credit": "",
      "description": "Interdisciplinary project. Students engage in one or more group research  projects.",
      "prerequisites": "4th year standing, enrolment in B. Cog. Sc. Honours.",
      "offerings": [
        "fall",
